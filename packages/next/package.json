{
  "name": "@pingback/next",
  "version": "0.1.0",
  "description": "Next.js SDK for Pingback — reliable cron jobs and background tasks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pingback": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "default": "./dist/handler.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest"
  },
  "keywords": [
    "pingback",
    "nextjs",
    "cron",
    "scheduled-jobs",
    "background-tasks",
    "vercel",
    "serverless"
  ],
  "author": "Pingback",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/champ3oy/pingback",
    "directory": "packages/next"
  },
  "homepage": "https://pingback.dev/docs/next",
  "bugs": {
    "url": "https://github.com/champ3oy/pingback/issues"
  },
  "dependencies": {
    "@pingback/core": "0.1.0",
    "glob": "^11.0.0"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.5.0",
    "next": "^15.0.0",
    "ts-node": "^10.9.0"
  }
}
