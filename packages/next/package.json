{
  "name": "@usepingback/next",
  "version": "0.4.1",
  "description": "Next.js SDK for Pingback — reliable cron jobs and background tasks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pingback": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "default": "./dist/handler.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest"
  },
  "keywords": [
    "pingback",
    "nextjs",
    "cron",
    "scheduled-jobs",
    "background-tasks",
    "vercel",
    "serverless"
  ],
  "author": "Pingback",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runpingback/pingback",
    "directory": "packages/next"
  },
  "homepage": "https://pingback.lol/docs/next",
  "bugs": {
    "url": "https://github.com/runpingback/pingback/issues"
  },
  "dependencies": {
    "@usepingback/core": "0.2.0",
    "dotenv": "^17.4.2",
    "glob": "^11.0.0",
    "jiti": "^2.6.1",
    "localtunnel": "^2.0.2"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "next": "^15.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
